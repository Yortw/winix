# Auto-detect text files and normalise line endings
* text=auto

# Force LF for source files (cross-platform consistency)
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.editorconfig text eol=lf

# Windows-specific files keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files — do not diff or merge
*.png binary
*.ico binary
*.zip binary
*.gz binary
*.br binary
*.zst binary
