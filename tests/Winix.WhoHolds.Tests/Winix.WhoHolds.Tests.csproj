<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <!-- Match the runtime InvariantGlobalization=true setting in the production csproj.
         Without this, framework ex.Message may produce localised text in tests that the
         shipped binary would not produce, hiding resource-key leak bugs. See
         feedback_invariant_globalization_resource_keys.md. -->
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.*" />
    <!-- Xunit.SkippableFact replaces silent early-return in platform-gated integration tests
         with a proper 'Skipped' status in test output. Without it, tests that early-return on
         the wrong OS show as 'Passed' in CI dashboards — a false positive. -->
    <PackageReference Include="Xunit.SkippableFact" Version="1.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Winix.WhoHolds\Winix.WhoHolds.csproj" />
  </ItemGroup>
</Project>
