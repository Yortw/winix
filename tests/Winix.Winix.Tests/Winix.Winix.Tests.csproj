<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <!-- Match the runtime UseSystemResourceKeys=true setting on the production csproj so
         framework exception .Message returns bare CoreLib resource keys here too — this is
         what makes the SafeError resource-key-leak regression tests meaningful. -->
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Winix.Winix\Winix.Winix.csproj" />
  </ItemGroup>
</Project>
