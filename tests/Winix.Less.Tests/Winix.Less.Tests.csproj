<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <!-- Match runtime InvariantGlobalization=true on the production csproj per
         feedback_invariant_globalization_resource_keys.md. Without this, framework
         ex.Message values may be locale-dependent in tests while production AOT runs
         InvariantGlobalization-true and would emit SR resource keys instead. Mandatory
         per the suite-wide rule (caught locally in F7 was already defending against
         this on the message-piping side). -->
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Winix.Less\Winix.Less.csproj" />
  </ItemGroup>
</Project>
