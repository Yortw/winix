<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <!-- Tier-2 re-verification 2026-05-06: mirror timeit.csproj's InvariantGlobalization=true so
         the test process exercises framework-thrown exception messages under the same runtime
         config as the shipped AOT binary. Without this, ex.Message resource-key leaks
         (e.g. "FileNameMissing" from Process.Start with empty FileName) render as localised
         English in tests but as raw SR keys in production. -->
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Mirror the shipping tool's UseSystemResourceKeys so resource-key-leak regression
         tests observe the same bare-CoreLib-key behaviour the published binary does. -->
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.*" />
    <!-- Xunit.SkippableFact replaces silent early-return in platform-gated tests with a
         proper 'Skipped' status. CommandRunnerTests has a Windows-skip gate that previously
         reported Passed on Windows CI by short-circuiting before any assertion ran. -->
    <PackageReference Include="Xunit.SkippableFact" Version="1.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Winix.TimeIt\Winix.TimeIt.csproj" />
  </ItemGroup>
</Project>
