<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <!-- Mirror the production csproj so framework ex.Message returns bare CoreLib resource
         keys (UseSystemResourceKeys=true) in tests too — otherwise SR-key-leak regressions
         are invisible locally. Part of the suite-wide resource-key-leak sweep. -->
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.*" />
    <!-- Round-1 review TA-I3 — replaces silent early-return-style platform gating with
         a proper 'Skipped' status. Backend tests that exercise platform-only binaries
         (notify-send, osascript, powershell.exe) were silently passing on the wrong OS. -->
    <PackageReference Include="Xunit.SkippableFact" Version="1.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Winix.Notify\Winix.Notify.csproj" />
  </ItemGroup>
</Project>
