<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <!-- InvariantGlobalization disabled so timezone and named-month parsing work in tests,
         matching the when console app's runtime environment. -->
    <InvariantGlobalization>false</InvariantGlobalization>
    <!-- Match the runtime UseSystemResourceKeys=true setting on the production csproj so
         framework exception .Message returns bare CoreLib resource keys here too. NOTE the
         deliberate combination: ICU stays ON (InvariantGlobalization=false) for TZ/month
         parsing, while system resource keys are also ON — this mirrors the shipped binary. -->
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Winix.When\Winix.When.csproj" />
  </ItemGroup>
</Project>
