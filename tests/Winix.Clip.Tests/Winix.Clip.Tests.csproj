<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <!-- Match the runtime csproj (src/clip/clip.csproj) so framework ex.Message strings
         return SR resource keys here too. Without this, tests render English on a
         non-Invariant test host while the AOT binary renders SR keys in production —
         masking the InvariantGlobalization-resource-key class of defects locally. -->
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Mirror the shipping tool's UseSystemResourceKeys so resource-key-leak regression
         tests observe the same bare-CoreLib-key behaviour the published binary does. -->
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.*" />
    <!-- Xunit.SkippableFact replaces silent early-return in platform-gated tests with a
         proper 'Skipped' status. The Windows clipboard tests previously used
         `if (!IsWindows) return;`, which reported them as Passed on Linux/macOS CI. -->
    <PackageReference Include="Xunit.SkippableFact" Version="1.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Winix.Clip\Winix.Clip.csproj" />
  </ItemGroup>
</Project>
