find . \-name \(dq*.cs\(dq | wargs \-P4 dotnet format {}

cat urls.txt | wargs \-n10 curl

find . \-name \(dq*.log\(dq | wargs \-\-dry\-run rm

find . \-name \(dq*.bak\(dq | wargs \-p rm

