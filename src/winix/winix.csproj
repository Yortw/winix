<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <OptimizationPreference>Size</OptimizationPreference>
    <StackTraceSupport>false</StackTraceSupport>
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>winix</ToolCommandName>
    <PackageId>Winix.Winix</PackageId>
    <Description>Cross-platform installer for the Winix CLI tool suite.</Description>
    <PackageTags>cli;command-line;cross-platform;windows;macos;linux;aot;dotnet-tool;winix;installer;suite;package-manager</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Winix.Winix\Winix.Winix.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="man\man1\winix.1" CopyToPublishDirectory="PreserveNewest" Link="share\man\man1\winix.1" />
    <Content Include="winix-manifest.json" CopyToPublishDirectory="PreserveNewest" Link="share\winix\winix-manifest.json" />
  </ItemGroup>
</Project>
