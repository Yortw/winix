<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <OptimizationPreference>Size</OptimizationPreference>
    <StackTraceSupport>false</StackTraceSupport>
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>qr</ToolCommandName>
    <PackageId>Winix.Qr</PackageId>
    <Description>Cross-platform QR code generator with helpers for Wi-Fi, SMS, mailto, geo, and tel.</Description>
    <PackageTags>cli;command-line;cross-platform;windows;macos;linux;aot;dotnet-tool;winix;qr-code;barcode;wifi;encoding</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Winix.Qr\Winix.Qr.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="man\man1\qr.1" CopyToPublishDirectory="PreserveNewest" Link="share\man\man1\qr.1" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
</Project>
