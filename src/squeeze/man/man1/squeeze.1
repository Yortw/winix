.SH EXAMPLES
.IP
.EX
squeeze data.csv

squeeze \-d data.csv.gz

squeeze \-\-brotli \-\-level 11 largefile.bin

squeeze \-\-zstd data.csv

cat data.csv | squeeze > data.csv.gz

squeeze \-c \-d archive.gz | head \-20

squeeze \-o compressed.gz data.csv

squeeze \-9 data.csv

squeeze *.log
