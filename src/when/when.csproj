<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <PublishAot>true</PublishAot>
    <!-- ICU is required for IANA timezone resolution on Windows and named-month parsing.
         This is intentionally false — unlike all other Winix tools which use InvariantGlobalization=true. -->
    <InvariantGlobalization>false</InvariantGlobalization>
    <OptimizationPreference>Size</OptimizationPreference>
    <StackTraceSupport>false</StackTraceSupport>
    <UseSystemResourceKeys>true</UseSystemResourceKeys>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>when</ToolCommandName>
    <PackageId>Winix.When</PackageId>
    <Description>Convert timestamps between formats, apply time arithmetic, and calculate durations.</Description>
    <PackageTags>cli;command-line;cross-platform;windows;macos;linux;aot;dotnet-tool;winix;datetime;timezone;timestamp;date</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Winix.When\Winix.When.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="man\man1\when.1" CopyToPublishDirectory="PreserveNewest" Link="share\man\man1\when.1" />
  </ItemGroup>
</Project>
